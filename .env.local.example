# =============================================================================
# Hype Up AI — 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください。
# .env.local は .gitignore に含まれており、リポジトリに commit されません。
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Supabase Dashboard → Project Settings → API から取得
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ⚠️  service_role key は RLS をバイパスします。サーバー専用（NEXT_PUBLIC_ を付けない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Site URL — Supabase Auth マジックリンクのリダイレクト先
# ローカル: http://localhost:3000
# 本番:    https://your-domain.com  （末尾スラッシュなし）
# Supabase Dashboard → Authentication → URL Configuration の Site URL と一致させること
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Anthropic
# https://console.anthropic.com/settings/keys から取得
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Claude モデル（省略可 — 省略時は lib/constants.ts のデフォルト値を使用）
# デフォルト: CLAUDE_CHUNK_MODEL=claude-haiku-4-5-20251001
#             CLAUDE_SYNTHESIS_MODEL=claude-sonnet-4-6
# -----------------------------------------------------------------------------
# CLAUDE_CHUNK_MODEL=claude-haiku-4-5-20251001
# CLAUDE_SYNTHESIS_MODEL=claude-sonnet-4-6
